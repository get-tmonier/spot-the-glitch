{
  "name": "spot-the-glitch",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --check src",
    "format:fix": "oxfmt --write src",
    "type-check": "tsgo --noEmit",
    "test": "bun test",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "fsd": "depcruise src --config .dependency-cruiser.cjs",
    "deps:check": "ncu",
    "deps:update": "ncu -u && bun install",
    "verify": "bun run type-check && bun run format && bun run lint && bun run fsd && bun run knip && bun test",
    "verify:fix": "bun run format:fix && bun run lint:fix && bun run knip:fix && bun run verify",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@vercel/analytics": "2.0.1",
    "@vercel/og": "0.11.1",
    "framer-motion": "12.38.0",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "recharts": "3.8.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.2",
    "@types/bun": "1.3.12",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260417.1",
    "dependency-cruiser": "17.3.10",
    "knip": "6.4.1",
    "npm-check-updates": "21.0.2",
    "oxfmt": "0.45.0",
    "oxlint": "1.60.0",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.3"
  }
}
